#!/bin/bash
# aiproxy - PoolProx3 management CLI
# Usage: aiproxy [start|stop|restart|status|logs|build|dev|migrate]
#
# SAFETY: this CLI manages ONLY the poolprox3 instance it ships with.
# It tracks its own process group via a PID file and kills only that
# group on stop — it never uses a global `pkill` on "bun src/index.ts",
# so a separate poolprox/poolprox2 instance on other ports is left alone.

set -euo pipefail

# --- Resolve project dir from this script's real location (follow symlinks) ---
SCRIPT_PATH="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT_PATH" ]; do
  SCRIPT_DIR=$(cd -P "$(dirname "$SCRIPT_PATH")" >/dev/null 2>&1 && pwd)
  SCRIPT_PATH=$(readlink "$SCRIPT_PATH")
  [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done
PROJECT_DIR=$(cd -P "$(dirname "$SCRIPT_PATH")" >/dev/null 2>&1 && pwd)

PID_FILE="$PROJECT_DIR/.aiproxy.pid"
LOG_FILE="$PROJECT_DIR/.aiproxy.log"
ENV_FILE="$PROJECT_DIR/.env"
START_CMD_MATCH="scripts/production.ts"   # used to verify a PID before killing

# --- Read a single KEY from .env without executing the file ---
read_env() {
  local key="$1" def="$2" val=""
  if [ -f "$ENV_FILE" ]; then
    val=$(grep -E "^${key}=" "$ENV_FILE" 2>/dev/null | tail -n1 | cut -d= -f2- | tr -d '\r')
  fi
  echo "${val:-$def}"
}

API_PORT=$(read_env PORT 1930)
DASH_PORT=$(read_env DASHBOARD_PORT 1931)

# --- Is the tracked instance alive? PID file must point at OUR command ---
running_pid() {
  [ -f "$PID_FILE" ] || return 1
  local pid
  pid=$(cat "$PID_FILE" 2>/dev/null || true)
  [ -n "${pid:-}" ] || { rm -f "$PID_FILE"; return 1; }
  if kill -0 "$pid" 2>/dev/null && ps -o args= -p "$pid" 2>/dev/null | grep -q "$START_CMD_MATCH"; then
    echo "$pid"; return 0
  fi
  rm -f "$PID_FILE"
  return 1
}

port_in_use() { ss -tlnp 2>/dev/null | grep -q ":$1 "; }

rotate_log() {
  if [ -f "$LOG_FILE" ]; then
    local size
    size=$(stat -c%s "$LOG_FILE" 2>/dev/null || echo 0)
    if [ "$size" -gt 5242880 ]; then
      tail -n 1000 "$LOG_FILE" > "$LOG_FILE.tmp" && mv "$LOG_FILE.tmp" "$LOG_FILE"
    fi
  fi
}

do_start() {
  if pid=$(running_pid); then
    echo "✅ aiproxy already running (PID $pid)"
    echo "   Backend:   http://localhost:$API_PORT"
    echo "   Dashboard: http://localhost:$DASH_PORT"
    return 0
  fi

  if port_in_use "$API_PORT"; then
    echo "❌ Port $API_PORT already in use by another process. Aborting."
    echo "   (poolprox3 defaults to 1930/1931 — check 'ss -tlnp | grep $API_PORT')"
    return 1
  fi
  if port_in_use "$DASH_PORT"; then
    echo "❌ Port $DASH_PORT already in use by another process. Aborting."
    return 1
  fi

  rotate_log
  echo "Starting aiproxy (poolprox3)..."
  cd "$PROJECT_DIR"
  # setsid → new session/process group so 'stop' can target ONLY our subtree.
  setsid bun scripts/production.ts --skip-build >> "$LOG_FILE" 2>&1 &
  local pid=$!
  echo "$pid" > "$PID_FILE"
  sleep 1.5

  if kill -0 "$pid" 2>/dev/null; then
    echo "✅ aiproxy started (PID $pid)"
    echo "   Backend:   http://localhost:$API_PORT"
    echo "   Dashboard: http://localhost:$DASH_PORT"
    echo "   Logs:      aiproxy logs"
  else
    rm -f "$PID_FILE"
    echo "❌ Failed to start. Last log lines:"
    tail -n 15 "$LOG_FILE" 2>/dev/null
    return 1
  fi
}

do_stop() {
  local pid
  if ! pid=$(running_pid); then
    echo "⏹️  aiproxy is not running (nothing to stop)"
    return 0
  fi

  # Kill ONLY this PID's process group — never a global pattern match.
  local pgid
  pgid=$(ps -o pgid= -p "$pid" 2>/dev/null | tr -d ' ')
  echo "Stopping aiproxy (PID $pid, group $pgid)..."
  if [ -n "$pgid" ]; then
    kill -TERM -"$pgid" 2>/dev/null || true
    local i=0
    while kill -0 "$pid" 2>/dev/null && [ $i -lt 20 ]; do sleep 0.25; i=$((i + 1)); done
    if kill -0 "$pid" 2>/dev/null; then
      kill -KILL -"$pgid" 2>/dev/null || true
      sleep 0.5
    fi
  fi
  rm -f "$PID_FILE"
  echo "⏹️  aiproxy stopped"
}

do_status() {
  if pid=$(running_pid); then
    local pgid
    pgid=$(ps -o pgid= -p "$pid" 2>/dev/null | tr -d ' ')
    echo "✅ aiproxy is running (PID $pid, group $pgid)"
    echo "   Backend:   http://localhost:$API_PORT  $(port_in_use "$API_PORT" && echo '(listening)' || echo '(not listening yet)')"
    echo "   Dashboard: http://localhost:$DASH_PORT  $(port_in_use "$DASH_PORT" && echo '(listening)' || echo '(not listening yet)')"
  else
    echo "⏹️  aiproxy is not running"
  fi
}

usage() {
  cat <<EOF
aiproxy — PoolProx3 management CLI

Usage: aiproxy <command>

  start      Start backend + dashboard in the background (ports $API_PORT/$DASH_PORT)
  stop       Stop this instance only (process-group scoped, safe for other instances)
  restart    Stop then start
  status     Show PID, group, and whether ports are listening
  logs [N]   Follow logs, or print last N lines
  build      Rebuild dashboard then restart
  dev        Run in foreground with Vite HMR (Ctrl-C to quit)
  migrate    Run database migrations
EOF
}

case "${1:-}" in
  start)   do_start ;;
  stop)    do_stop ;;
  restart) do_stop; sleep 1; do_start ;;
  status)  do_status ;;
  logs)
    if [ -n "${2:-}" ]; then tail -n "$2" "$LOG_FILE"; else tail -f "$LOG_FILE"; fi
    ;;
  build)
    echo "🔨 Building dashboard..."
    (cd "$PROJECT_DIR/dashboard" && bun run build)
    do_stop; sleep 1; do_start
    ;;
  dev)
    cd "$PROJECT_DIR" && exec bun scripts/start.ts
    ;;
  migrate)
    cd "$PROJECT_DIR" && exec bun run migrate
    ;;
  ""|help|-h|--help) usage ;;
  *) echo "Unknown command: $1"; echo; usage; exit 1 ;;
esac
